) %>%
ungroup()
ggplot(rank_summary,
aes(x = reorder(feature_set, mean_rank),
y = mean_rank,
color = algorithm)) +
geom_point(size = 3) +
geom_errorbar(
aes(ymin = mean_rank - sd_rank,
ymax = mean_rank + sd_rank),
width = 0.2
) +
coord_flip() +
labs(
x = "Feature set",
y = "Mean rank across datasets (lower = better)",
title = "Relative performance of feature sets across datasets",
color = "Algorithm"
) +
theme_bw(base_size = 12)
