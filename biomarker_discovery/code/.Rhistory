# Figure 1 panel B
# Distribution of genes across temporal classes
# No piping operators used
# User inputs
n_total <- 6099
n_trait <- 1356
n_state <- 1327
res_dir <- "~/Desktop/work_repo/github/cross_study_analysis/output/"
# Derived
n_other <- n_total - n_trait - n_state
if (n_other < 0) stop("Counts do not sum correctly. Check n_total, n_trait, n_state.")
plot_df <- data.frame(
class = factor(
c("Trait genes", "State genes", "Other genes"),
levels = c("Trait genes", "State genes", "Other genes")
),
n = c(n_trait, n_state, n_other)
)
plot_df$prop <- plot_df$n / sum(plot_df$n)
plot_df$label <- paste0(plot_df$n, " (", sprintf("%.1f", 100 * plot_df$prop), "%)")
# Stack order so Trait appears at the top (to emphasize it)
plot_df$class <- factor(
plot_df$class,
levels = c("Trait genes", "State genes", "Other genes")
)
# Direct labels inside segments (no legend needed)
plot_df$label <- paste0(
as.character(plot_df$class), "\n",
format(plot_df$n, big.mark = ","), " (", sprintf("%.1f", 100 * plot_df$prop), "%)"
)
# Output files
out_png <- paste0(res_dir, "Figure1_temporal_class_distribution.png")
out_pdf <- paste0(res_dir,"Figure1_temporal_class_distribution.pdf")
# Graph Colors
trait_col <- "#84cbeb"
state_col <- "#f6c6ad"
other_col <- "#bbc5c9"
# Stacked bar showing proportions
suppressPackageStartupMessages(library(ggplot2))
p_stacked <- ggplot(plot_df, aes(x = 1, y = prop, fill = class)) +
geom_col(
width = 0.50,
color = "white",      # thin white separators
linewidth = 0.60
) +
geom_text(
aes(label = label),
position = position_stack(vjust = 0.5),
size = 5.8,           # bigger text for PPT
fontface = "bold",
lineheight = 0.95
) +
scale_fill_manual(
values = c(
"Trait genes" = trait_col,
"State genes" = state_col,
"Other genes" = other_col
)
) +
scale_y_continuous(
limits = c(0, 1),
expand = c(0, 0),
breaks = NULL,
labels = NULL
) +
labs(x = NULL, y = NULL, fill = NULL) +
theme_classic(base_size = 12) +
theme(
axis.text = element_blank(),
axis.ticks = element_blank(),
axis.line = element_blank(),
legend.position = "none",
plot.margin = margin(0, 0, 0, 0, unit = "pt")
)
# Export
# ggsave(out_pdf, p_stacked, width = 4.6, height = 2.4, units = "in", device = cairo_pdf)
ggsave(out_png, p_stacked, width = 4.6, height = 3.2, units = "in", dpi = 600, bg = "transparent")
# non-bolded
out_png <- paste0(res_dir, "Figure1_temporal_class_distribution_nonbold.png")
p_stacked <- ggplot(plot_df, aes(x = 1, y = prop, fill = class)) +
geom_col(
width = 0.50,
color = "white",      # thin white separators
linewidth = 0.60
) +
geom_text(
aes(label = label),
position = position_stack(vjust = 0.5),
size = 5.8,           # bigger text for PPT
# fontface = "bold",
lineheight = 0.95
) +
scale_fill_manual(
values = c(
"Trait genes" = trait_col,
"State genes" = state_col,
"Other genes" = other_col
)
) +
scale_y_continuous(
limits = c(0, 1),
expand = c(0, 0),
breaks = NULL,
labels = NULL
) +
labs(x = NULL, y = NULL, fill = NULL) +
theme_classic(base_size = 12) +
theme(
axis.text = element_blank(),
axis.ticks = element_blank(),
axis.line = element_blank(),
legend.position = "none",
plot.margin = margin(0, 0, 0, 0, unit = "pt")
)
# Export
# ggsave(out_pdf, p_stacked, width = 4.6, height = 2.4, units = "in", device = cairo_pdf)
ggsave(out_png, p_stacked, width = 4.6, height = 3.2, units = "in", dpi = 600, bg = "transparent")
